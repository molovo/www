block vars

doctype html
html

  head
    meta(charset='utf8')
    meta(http-equiv='X-UA-Compatible', content='IE=edge, chrome=1')
    meta(name='description', content='The home of developer James Dinsdale')
    meta(name='author', content= "James Dinsdale")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    - var title = typeof post !== 'undefined' ? post.title + ' | molovo' : (title || _path)
    title= title

    script var pageTitle = '#{title}'

    != css('/')

  body(class=bodyClass)
    block content

    include /includes/_footer

    != js('/')

    script(src='https://use.typekit.net/mmt3fau.js')
    script try{Typekit.load({ async: true });}catch(e){}
